llm:
  api_key: "sk-xxxxxxxxx"            # 可通过 LLM_API_KEY 环境变量覆盖
  base_url: "https://api.openai.com/v1"
  boss_model: "gpt-4o"
  researcher_model: "gpt-3.5-turbo"
  content_model: "gpt-4-turbo"
  visual_model: "gpt-4o"
  # embedding_provider: "openai"
  # embedding_model: "text-embedding-3-small"
  # embedding_dim: 384
  embedding_provider: "ark"                   # 火山引擎方舟
  embedding_model: "ep-2025xxxx-xxxxx"       # 替换为您的 Endpoint ID
  embedding_dim: 1024                         # 根据模型调整维度，例如豆包模型通常为 1024
